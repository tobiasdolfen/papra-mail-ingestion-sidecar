# IMAP connection (required)
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_FOLDER=INBOX
IMAP_PROCESSED_FOLDER=Processed
POLL_INTERVAL_MS=30000

# Webhook output (optional if OUTPUT_DIR is set)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Directory output (optional if WEBHOOK_URL is set)
OUTPUT_DIR=
